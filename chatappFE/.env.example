# Example Environment Variables
# Copy this file to .env.local and update with your values

# Backend API Gateway URL - all REST API requests route through this
# Format: http://host:port/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# WebSocket Gateway URL - real-time connections (chat, presence, friendship)
# Format: ws://host:port (no /api/v1; gateway routes /ws/{service}/** directly)
# For production, use wss:// for secure WebSocket
VITE_WS_URL=ws://localhost:8080

# Development mode flag
VITE_DEV=true
