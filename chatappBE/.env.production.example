# ─────────────────────────────────────────────────────────────────────────────
# ChatApp Production Environment Contract
# Copy this file to .env.production and fill in ALL required values.
# Never commit .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED: service-specific database contracts (DB name + dedicated app role).
# NOTE: Key names match local contract exactly; values are production-specific.
AUTH_DATABASE_NAME=auth_service
AUTH_DATABASE_USER=auth_user
AUTH_DATABASE_PASSWORD=CHANGE_ME
USER_DATABASE_NAME=user_service
USER_DATABASE_USER=user_user
USER_DATABASE_PASSWORD=CHANGE_ME
CHAT_DATABASE_NAME=chat_service
CHAT_DATABASE_USER=chat_user
CHAT_DATABASE_PASSWORD=CHANGE_ME
FRIENDSHIP_DATABASE_NAME=friendship_service
FRIENDSHIP_DATABASE_USER=friendship_user
FRIENDSHIP_DATABASE_PASSWORD=CHANGE_ME
NOTIFICATION_DATABASE_NAME=notification_service
NOTIFICATION_DATABASE_USER=notification_user
NOTIFICATION_DATABASE_PASSWORD=CHANGE_ME

# ── Google OAuth2 (auth-service) ─────────────────────────────────────────────
# REQUIRED: Google Cloud credentials for OAuth2 login flow.
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
# REQUIRED: Public base URL used to build the OAuth2 redirect_uri sent to Google.
# Must match exactly one of the Authorized Redirect URIs in Google Cloud Console:
#   https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Registered URI should be: <OAUTH2_REDIRECT_BASE_URL>/login/oauth2/code/google
OAUTH2_REDIRECT_BASE_URL=https://api.chatweb.nani.id.vn

# ── Resend (auth-service transactional email provider) ───────────────────────
# REQUIRED in production when forgot-password/reset email is enabled.
RESEND_API_KEY=CHANGE_ME
RESEND_FROM=CHANGE_ME
# OPTIONAL: Override only if you use a non-default Resend endpoint.
RESEND_BASE_URL=https://api.resend.com

# ── Cloudinary (upload-service) ───────────────────────────────────────────────
# REQUIRED: Cloudinary project credentials for file upload.
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# ── Domain / CORS ─────────────────────────────────────────────────────────────
# REQUIRED: Frontend origin used in auth emails and CORS policy.
# Must match the actual FE domain served by Nginx.
FRONTEND_URL=https://chatweb.nani.id.vn

# REQUIRED: Comma-separated list of allowed CORS origins for all services.
# Include both FE domain and API domain.
CORS_ALLOWED_ORIGINS=https://chatweb.nani.id.vn,https://api.chatweb.nani.id.vn

# ── Gateway ───────────────────────────────────────────────────────────────────
# OPTIONAL: Extra seconds of JWT clock skew tolerance at the gateway.
GATEWAY_JWT_CLOCK_SKEW_SECONDS=60
